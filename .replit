modules = ["php-8.2", "nodejs-20", "web", "bash"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
APP_DEBUG = "true"
APP_ENV = "local"
APP_LOCALE = "id"
APP_NAME = "Absensi QR - Server Pusat"
APP_TIMEZONE = "UTC"
CACHE_STORE = "database"
CURRENT_STABLE_VERSION = "1.0.0"
DB_CONNECTION = "pgsql"
DB_DATABASE = "absensi_monitor"
DB_HOST = "helium"
DB_PASSWORD = "password"
DB_PORT = "5432"
DB_USERNAME = "postgres"
DEV_EMAIL = "developer@yourdomain.com"
HEARTBEAT_LOG_RETENTION_DAYS = "90"
ONLINE_THRESHOLD_MINUTES = "90"
QUEUE_CONNECTION = "database"
SESSION_DRIVER = "database"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
